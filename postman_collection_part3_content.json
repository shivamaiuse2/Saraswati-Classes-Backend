    {
      "name": "📤 File Upload",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": {"mode": "formdata", "formdata": [{"key": "image", "type": "file", "src": "/path/to/image.jpg"}, {"key": "folder", "value": "course-images"}]},
            "url": {"raw": "{{base_url}}/api/v1/upload/image", "host": ["{{base_url}}"], "path": ["api", "v1", "upload", "image"]}
          },
          "response": []
        },
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": {"mode": "formdata", "formdata": [{"key": "document", "type": "file", "src": "/path/to/document.pdf"}, {"key": "folder", "value": "study-materials"}]},
            "url": {"raw": "{{base_url}}/api/v1/upload/document", "host": ["{{base_url}}"], "path": ["api", "v1", "upload", "document"]}
          },
          "response": []
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
