{
  "info": {
    "_postman_id": "saraswati-content-management-part3",
    "name": "Saraswati Classes - Content & Upload APIs (Part 3)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Content Management (Blogs, Resources, Gallery, Results), Banner Management, File Upload, Notifications\n\n⚠️ Requires admin authentication for most endpoints"
