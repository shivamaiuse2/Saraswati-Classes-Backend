generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/client"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AdminProfile {
  id        String   @id
  userId    String   @unique
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BannerPoster {
  id           String      @id
  imageUrl     String
  testSeriesId String?
  courseId     String?
  enabled      Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime
  Course       Course?     @relation(fields: [courseId], references: [id])
  TestSeries   TestSeries? @relation(fields: [testSeriesId], references: [id])

  @@index([courseId])
  @@index([testSeriesId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Blog {
  id        String   @id
  title     String
  content   String
  image     String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime
  createdBy String
  isActive  Boolean  @default(true)
  User      User     @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Certificate {
  id             String         @id
  studentId      String
  title          String
  issuedDate     DateTime       @default(now())
  certificateUrl String
  createdAt      DateTime       @default(now())
  StudentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContactMessage {
  id        String   @id
  name      String
  email     String
  phone     String
  message   String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Course {
  id               String             @id
  title            String
  category         CourseCategory
  description      String
  fullDescription  String
  mode             String
  image            String
  timing           String
  days             String
  pricePerSubject  Float
  subjects         String[]
  duration         String?
  demoVideoUrl     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  createdBy        String
  isActive         Boolean            @default(true)
  BannerPoster     BannerPoster[]
  User             User               @relation(fields: [createdBy], references: [id])
  CourseChapter    CourseChapter[]
  CourseEnrollment CourseEnrollment[]

  @@index([category])
  @@index([createdBy])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CourseChapter {
  id              String   @id
  courseId        String
  title           String
  description     String
  videoUrl        String?
  chapterNumber   Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  testLink        String?
  testDescription String?
  Course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CourseEnrollment {
  id             String         @id
  studentId      String
  courseId       String
  enrolledAt     DateTime       @default(now())
  status         String         @default("ACTIVE")
  Course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  StudentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([courseId])
  @@index([studentId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Enrollment {
  id             String           @id
  name           String
  email          String
  phone          String
  message        String
  courseOrSeries String
  status         EnrollmentStatus @default(PENDING)
  studentId      String?
  username       String?
  password       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  userId         String?
  StudentProfile StudentProfile?  @relation(fields: [studentId], references: [id])
  User           User?            @relation(fields: [userId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model FeatureFlag {
  id          String            @id
  name        String            @unique
  description String
  status      FeatureFlagStatus @default(ENABLED)
  config      Json
  createdAt   DateTime          @default(now())
  updatedAt   DateTime
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model GalleryItem {
  id        String   @id
  title     String
  image     String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime
  createdBy String
  isActive  Boolean  @default(true)
  User      User     @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Inquiry {
  id        String        @id
  name      String
  email     String
  phone     String
  message   String
  status    InquiryStatus @default(PENDING)
  userId    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime
  User      User?         @relation(fields: [userId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Notification {
  id        String   @id
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PopupContent {
  id          String   @id
  title       String
  description String
  ctaText     String
  ctaLink     String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Resource {
  id          String   @id
  title       String
  description String
  price       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  createdBy   String
  isActive    Boolean  @default(true)
  User        User     @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Result {
  id             String          @id
  name           String
  marks          String
  exam           String
  image          String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  createdBy      String
  isActive       Boolean         @default(true)
  studentId      String?
  User           User            @relation(fields: [createdBy], references: [id])
  StudentProfile StudentProfile? @relation(fields: [studentId], references: [id])

  @@index([createdBy])
  @@index([studentId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model StudentProfile {
  id                   String                 @id
  userId               String                 @unique
  name                 String
  phone                String?
  address              String?
  standard             String?
  board                String?
  status               StudentStatus          @default(ACTIVE)
  profileImage         String?
  dateOfBirth          DateTime?
  guardianName         String?
  guardianPhone        String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  username             String?                @unique
  plainPassword        String?
  Certificate          Certificate[]
  CourseEnrollment     CourseEnrollment[]
  Enrollment           Enrollment[]
  Result               Result[]
  User                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  TestResult           TestResult[]
  TestSeriesEnrollment TestSeriesEnrollment[]

  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Test {
  id           String     @id
  testSeriesId String
  testNumber   Int
  title        String
  description  String?
  testLink     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  TestSeries   TestSeries @relation(fields: [testSeriesId], references: [id], onDelete: Cascade)

  @@index([testSeriesId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TestResult {
  id             String         @id
  studentId      String
  testSeriesId   String?
  testName       String
  marksObtained  Int
  totalMarks     Int
  percentage     Float
  grade          String?
  testDate       DateTime       @default(now())
  createdAt      DateTime       @default(now())
  StudentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  TestSeries     TestSeries?    @relation(fields: [testSeriesId], references: [id])

  @@index([studentId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TestSeries {
  id                   String                 @id
  title                String
  overview             String
  features             String[]
  testPattern          String
  benefits             String[]
  image                String
  ctaLabel             String
  demoTestLink         String
  heroPosterThumbnail  String
  showInHeroPoster     Boolean                @default(false)
  testsCount           Int
  mode                 TestSeriesMode
  price                String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  createdBy            String
  isActive             Boolean                @default(true)
  BannerPoster         BannerPoster[]
  Test                 Test[]
  TestResult           TestResult[]
  User                 User                   @relation(fields: [createdBy], references: [id])
  TestSeriesEnrollment TestSeriesEnrollment[]

  @@index([createdBy])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TestSeriesEnrollment {
  id             String         @id
  studentId      String
  testSeriesId   String
  enrolledAt     DateTime       @default(now())
  status         String         @default("ACTIVE")
  StudentProfile StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  TestSeries     TestSeries     @relation(fields: [testSeriesId], references: [id], onDelete: Cascade)

  @@unique([studentId, testSeriesId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id             String          @id
  email          String          @unique
  password       String
  role           UserRole
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  AdminProfile   AdminProfile?
  Blog           Blog[]
  Course         Course[]
  Enrollment     Enrollment[]
  GalleryItem    GalleryItem[]
  Inquiry        Inquiry[]
  Notification   Notification[]
  Resource       Resource[]
  Result         Result[]
  StudentProfile StudentProfile?
  TestSeries     TestSeries[]

  @@index([role])
}

enum BannerStatus {
  ACTIVE
  INACTIVE
}

enum CourseCategory {
  FOUNDATION
  SCIENCE
  COMPETITIVE
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FeatureFlagStatus {
  ENABLED
  DISABLED
}

enum InquiryStatus {
  PENDING
  RESOLVED
  FOLLOW_UP
}

enum StudentStatus {
  ACTIVE
  BLOCKED
}

enum TestSeriesMode {
  ONLINE
  OFFLINE
  OMR_BASED
  BOARD_STYLE
}

enum UserRole {
  ADMIN
  STUDENT
}
