# Environment Variables Configuration Example

# Database Configuration (Required for Vercel - use Supabase or PostgreSQL connection string)
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Server Configuration
PORT=3001
NODE_ENV=production
API_BASE_URL=https://your-app.vercel.app

# JWT Configuration (Required)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this
REFRESH_TOKEN_EXPIRES_IN=7d

# Cloudinary Configuration (Required for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Configuration (Required for email notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Saraswati Classes <noreply@saraswaticlasses.com>"

# Admin Configuration
ADMIN_EMAIL=admin@saraswaticlasses.com
ADMIN_PASSWORD=change-this-secure-password

# Contact Notifications
CONTACT_NOTIFICATION_EMAIL=shivamaiuse1@gmail.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5000

# Logging
LOG_LEVEL=info

# CORS Configuration (Add your frontend Vercel URL)
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Feature Flags Default
FEATURE_BANNERS_ENABLED=true
FEATURE_TEST_SERIES_ENABLED=true
FEATURE_ENROLLMENTS_ENABLED=true
